diff --git a/ReactNativeHealthkit.podspec b/ReactNativeHealthkit.podspec
index e0d40dcfd0ee295b0dbe6113855bf24b2b8d8efe..f42009c26fda225f6a60c2d579cb0b27436e5dd6 100644
--- a/ReactNativeHealthkit.podspec
+++ b/ReactNativeHealthkit.podspec
@@ -37,10 +37,23 @@ Pod::Spec.new do |s|
 
   # Workaround for Swift 6.2 (Xcode 26): shared_ptr lost automatic CxxConvertibleToBool conformance,
   # causing nitrogen-generated Bool(fromCxx:) calls to fail. Replace with use_count() > 0.
-  # This can be removed once nitrogen fixes the codegen template upstream.
+  # Also fixes std::optional<Enum>.has_value() calling convention mismatch on Xcode 16.x
+  # by routing through the C++ bridge helper functions instead of direct Swift method calls.
   s.script_phase = {
     :name => '[ReactNativeHealthkit] Fix Swift 6.2 CxxConvertibleToBool',
-    :script => "perl -i -pe 's/Bool\\(fromCxx: cachedCxxPart\\)/cachedCxxPart.use_count() > 0/g' \"${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/\"*Spec_cxx.swift 2>/dev/null || true",
+    :script => <<~'SCRIPT',
+      set -e
+      # Fix 1: Swift 6.2 CxxConvertibleToBool
+      perl -i -pe 's/Bool\(fromCxx: cachedCxxPart\)/cachedCxxPart.use_count() > 0/g' "${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/"*Spec_cxx.swift 2>/dev/null || true
+      # Fix 2: std::optional<Enum>.has_value() calling convention mismatch (Xcode 16.x)
+      # Replace direct .has_value() calls with bridge helper function calls
+      perl -i -pe 's/self\.__metadataWeatherCondition\.has_value\(\)/bridge.has_value_std__optional_WeatherCondition_(self.__metadataWeatherCondition)/g' "${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/"*.swift 2>/dev/null || true
+      perl -i -pe 's/self\.__metadataInsulinDeliveryReason\.has_value\(\)/bridge.has_value_std__optional_InsulinDeliveryReason_(self.__metadataInsulinDeliveryReason)/g' "${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/"*.swift 2>/dev/null || true
+      perl -i -pe 's/self\.__metadataHeartRateMotionContext\.has_value\(\)/bridge.has_value_std__optional_HeartRateMotionContext_(self.__metadataHeartRateMotionContext)/g' "${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/"*.swift 2>/dev/null || true
+      perl -i -pe 's/self\.__workoutActivityType\.has_value\(\)/bridge.has_value_std__optional_WorkoutActivityType_(self.__workoutActivityType)/g' "${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/"*.swift 2>/dev/null || true
+      perl -i -pe 's/self\.__operatorType\.has_value\(\)/bridge.has_value_std__optional_ComparisonPredicateOperator_(self.__operatorType)/g' "${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/"*.swift 2>/dev/null || true
+      perl -i -pe 's/self\.__locationType\.has_value\(\)/bridge.has_value_std__optional_WorkoutSessionLocationType_(self.__locationType)/g' "${PODS_TARGET_SRCROOT}/nitrogen/generated/ios/swift/"*.swift 2>/dev/null || true
+    SCRIPT
     :execution_position => :before_compile,
   }
 
